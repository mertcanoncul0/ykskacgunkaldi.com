---
import "../styles/global.css";
import Header from "../components/Header.astro";
import { Footer } from "../components/Footer";
import SideNav from "../components/SideNav.astro";
import { site, socialLinks } from "../lib/site";
import { getExams } from "../lib/pocketbase";
import hepta400Latin from "@fontsource/hepta-slab/files/hepta-slab-latin-400-normal.woff2?url";
import hepta400LatinExt from "@fontsource/hepta-slab/files/hepta-slab-latin-ext-400-normal.woff2?url";
import hepta600Latin from "@fontsource/hepta-slab/files/hepta-slab-latin-600-normal.woff2?url";
import hepta600LatinExt from "@fontsource/hepta-slab/files/hepta-slab-latin-ext-600-normal.woff2?url";

const navExams = await getExams();
const headerExams = navExams.map((exam) => ({
  slug: exam.slug,
  name: exam.name,
}));

interface Props {
  title: string;
  description: string;
  path?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  ogImageAlt?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  path,
  ogType = "website",
  ogImage,
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
  ogImageAlt,
  structuredData,
} = Astro.props;

const canonicalPath = path ?? Astro.url.pathname;
const canonicalUrl = `${site.url}${canonicalPath}`;
const resolvedOgImage = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : `${site.url}${ogImage}`
  : `${site.url}${site.ogImage}`;
const resolvedOgImageAlt = ogImageAlt || title;
const sameAs = socialLinks.map((link) => link.href);

const siteJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: site.name,
    url: site.url,
    logo: `${site.url}${site.logo}`,
    sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    sameAs,
    inLanguage: "tr-TR",
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${site.url}/arama?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  },
];

const extraJsonLd = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];

const allJsonLd = [...siteJsonLd, ...extraJsonLd];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="google-site-verification"
      content="Vgk0t-MjIkPo3QPmja7ly7jEKT_GqBhfD8s47ZkRKSA"
    />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="tr" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <meta name="theme-color" content={site.themeColor} />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link
      rel="apple-touch-icon"
      type="image/png"
      sizes="180x180"
      href="/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/android-chrome-192x192.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href="/android-chrome-512x512.png"
    />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={site.name}
      href="/rss.xml"
    />

    <!-- Yandex -->
    <meta name="yandex-verification" content="df7cdb4351ae6da7" />

    <link
      rel="preload"
      href={hepta400Latin}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={hepta400LatinExt}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={hepta600Latin}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={hepta600LatinExt}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Google tag (gtag.js): dataLayer early, network script after idle -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      window.gtag = window.gtag || gtag;

      const loadGoogleTag = () => {
        if (window.__gtagLoaded) return;
        window.__gtagLoaded = true;
        const script = document.createElement("script");
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=G-Q7MC7YC7WJ";
        document.head.appendChild(script);
        gtag("js", new Date());
        gtag("config", "G-Q7MC7YC7WJ", {
          allow_google_signals: false,
          allow_ad_personalization_signals: false,
        });
      };

      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(loadGoogleTag, { timeout: 3500 });
      } else {
        window.addEventListener("load", () => window.setTimeout(loadGoogleTag, 1200), {
          once: true,
        });
      }
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    {
      ogType === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === "article" && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime} />
      )
    }
    {
      ogType === "article" && author && (
        <meta property="article:author" content={author} />
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={resolvedOgImageAlt} />

    <!-- Structured data -->
    {
      allJsonLd.map((data) => (
        <script type="application/ld+json" set:html={JSON.stringify(data)} />
      ))
    }

    <!--
      Hepta Slab artık self-hosted (bkz. global.css'teki @fontsource/hepta-slab
      import'ları) — fonts.googleapis.com/fonts.gstatic.com'a artık hiçbir
      istek gitmiyor, bu yüzden o origin'lere preconnect de kaldırıldı.
      Tek kalan dış kaynak hint'i, Cloudflare proxy arkasındaysa otomatik
      enjekte edilen Web Analytics beacon'ı için (önceden bu hint hiç
      yoktu, Lighthouse "missing preconnect" olarak işaretliyordu).
    -->
    <link
      rel="preconnect"
      href="https://static.cloudflareinsights.com"
      crossorigin
    />
  </head>
  <body
    class="font-body-md text-body-md text-on-surface bg-surface overflow-x-hidden"
  >
    <!-- Sidebar açık durumunu sayfa boyamadan önce uygula (flash'ı önler) -->
    <script is:inline>
      if (localStorage.getItem("sidebar-open") === "true") {
        document.body.classList.add("sidebar-open");
      }
    </script>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[70] focus:bg-primary focus:text-on-primary focus:px-4 focus:py-2 focus:font-label-md"
    >
      İçeriğe atla
    </a>
    <Header exams={headerExams} />
    <SideNav exams={navExams} />
    <main id="main-content" class="app-main pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
