---
import Layout from '../layouts/Layout.astro';
import { KonuDagilimiClient } from '../components/KonuDagilimiClient';
import { site } from '../lib/site';
import { getExams, getSubjects, getTopicDistributions } from '../lib/pocketbase';

const [exams, subjects, distributions] = await Promise.all([
  getExams(),
  getSubjects(),
  getTopicDistributions(),
]);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Konu Dağılımı', item: `${site.url}/konu-dagilimi` },
  ],
};
---

<Layout
  title="YKS, TYT ve AYT Konu Dağılımı | Yıllara Göre Çıkan Konular"
  description="YKS, TYT ve AYT konu dağılımını yıllara göre inceleyin; soru metni yayımlamadan konu başlığı ve soru sayısı analizleriyle çalışma önceliği belirleyin."
  structuredData={breadcrumbJsonLd}
>
  <KonuDagilimiClient
    client:load
    exams={exams}
    subjects={subjects}
    distributions={distributions}
    titleOverride="YKS, TYT ve AYT Konu Dağılımı"
    descriptionOverride="Yıllara göre çıkan konuları ve soru sayılarını inceleyin; TYT ve AYT çalışma planınızı konu ağırlıklarına göre güncelleyin."
  />
</Layout>
