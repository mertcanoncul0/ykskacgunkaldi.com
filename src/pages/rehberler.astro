---
import Layout from '../layouts/Layout.astro';
import { site } from '../lib/site';
import { getExams } from '../lib/pocketbase';
import { Icon } from '../lib/icons';
import { homeSelectionLandingPaths } from '../data/exam-landing-pages';

const exams = await getExams();

const examIcons: Record<string, string> = {
  yks: 'school',
  lgs: 'menu_book',
  dgs: 'trending_up',
  kpss: 'work',
  ales: 'psychology',
  msu: 'military_tech',
};

const resourceBlocks = [
  {
    title: 'Canlı Sayaçlar',
    icon: 'timer',
    body: 'YKS, TYT, AYT, LGS, KPSS, DGS ve ALES için güncel geri sayım sayfalarına ulaşın.',
    href: '/yks-kac-gun-kaldi',
    cta: 'YKS Sayacını Aç',
  },
  {
    title: 'Puan Hesaplama',
    icon: 'calculate',
    body: 'Netlerinizi girerek YKS, TYT, AYT ve diğer sınavlar için tahmini puanınızı hesaplayın.',
    href: '/puan-hesaplama/yks',
    cta: 'Puan Hesapla',
  },
  {
    title: 'Konu Dağılımı',
    icon: 'bar_chart',
    body: 'TYT, AYT ve LGS konularını soru dağılımına göre inceleyip çalışma önceliğinizi belirleyin.',
    href: '/konu-dagilimi',
    cta: 'Konuları İncele',
  },
  {
    title: 'Çalışma ve Takip Araçları',
    icon: 'edit_note',
    body: 'Haftalık çalışma programı oluşturun, deneme netlerinizi kaydedin ve gelişiminizi takip edin.',
    href: '/yks-calisma-programi',
    cta: 'Program Oluştur',
  },
  {
    title: 'Blog Rehberleri',
    icon: 'article',
    body: 'Çalışma planı, deneme analizi, tercih dönemi ve sınav hazırlığı yazılarını okuyun.',
    href: '/blog',
    cta: 'Blogu Aç',
  },
] as const;

const secondaryLinks = [
  { label: 'Deneme Net Takip', href: '/deneme-net-takip-tablosu', icon: 'history' },
  { label: 'Başarı Sıralaması Tahmini', href: '/basari-siralamasi-tahmini', icon: 'trending_up' },
  { label: '2027 YKS Takvimi', href: '/2027-yks-takvimi', icon: 'calendar_month' },
] as const;

// Her sınavın gerçek "guideTitle"/"guideParagraphs" alanları (PocketBase'de
// zaten ana sayfanın SEO rehber bölümünde kullanılıyor) burada kaynak kartına
// dönüştürülür. Sayfa herhangi bir danışmanlık hizmeti vaadi vermez; gerçek
// araçlara ve mevcut rehber içeriklerine yönlendirir.
const guides = exams
  .filter((e) => e.guideTitle && e.guideParagraphs && e.guideParagraphs.length > 0)
  .map((e) => ({
    slug: e.slug,
    name: e.name,
    title: e.guideTitle!,
    summary: e.guideParagraphs![0]?.body || e.heroDescription,
    icon: examIcons[e.slug] || 'auto_stories',
    href: homeSelectionLandingPaths[e.slug] || '/sinavlar',
  }));

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Sınav Rehberi', item: `${site.url}/rehberler` },
  ],
};
---

<Layout
  title="Sınav Rehberi ve Ücretsiz Hazırlık Araçları | YKS Kaç Gün Kaldı"
  description="YKS canlı sayaç, puan hesaplama, konu dağılımı, çalışma programı ve deneme net takip araçlarına tek sayfadan ulaşın."
  structuredData={breadcrumbJsonLd}
>
  <div class="px-margin-mobile md:px-margin-desktop">
    <div class="max-w-container-max mx-auto py-section-gap">
      <section class="mb-section-gap">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-end">
          <div class="md:col-span-8">
            <span class="font-label-sm text-label-sm text-text-muted uppercase tracking-[0.2em] mb-4 block">Ücretsiz Hazırlık Kaynakları</span>
            <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-6">Sınav Rehberi</h1>
            <p class="font-body-lg text-body-lg text-text-muted max-w-2xl">
              YKS’ye kalan süreyi takip edin, puanınızı hesaplayın, konu dağılımına göre çalışma planınızı güncelleyin.
            </p>
          </div>
          <div class="md:col-span-4">
            <div class="border border-border-subtle bg-surface-container-low p-6">
              <p class="font-label-sm text-label-sm uppercase tracking-widest text-primary mb-3">Bağımsız araç sitesi</p>
              <p class="font-body-md text-body-md text-text-muted">
                Resmi kurum sitesi değildir; tarihler ve tahmini puanlar bilgilendirme amacıyla sunulur.
              </p>
            </div>
          </div>
        </div>
        <div class="h-px bg-border-subtle mt-12"></div>
      </section>

      <section class="mb-section-gap" aria-labelledby="resource-title">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
          <div>
            <h2 id="resource-title" class="font-headline-lg text-headline-lg uppercase tracking-tight mb-3">Araçlar ve Kaynaklar</h2>
            <p class="font-body-md text-body-md text-text-muted max-w-2xl">
              Hazırlık sürecinde en sık gereken sayaç, hesaplama, konu takibi ve planlama araçlarını tek merkezden açın.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
          {resourceBlocks.map((item) => (
            <a href={item.href} class="group border border-border-subtle bg-white-pure p-8 transition-all hover:border-black-pure block">
              <div class="flex items-start justify-between gap-4 mb-8">
                <Icon name={item.icon} size={36} className="text-primary" />
                <Icon name="north_east" size={16} className="text-text-muted group-hover:text-primary transition-colors" />
              </div>
              <h3 class="font-headline-md text-headline-md text-primary mb-3">{item.title}</h3>
              <p class="font-body-md text-body-md text-text-muted mb-6">{item.body}</p>
              <span class="font-label-sm text-label-sm uppercase tracking-widest text-primary">{item.cta}</span>
            </a>
          ))}
        </div>
        <div class="flex flex-wrap gap-3 mt-8">
          {secondaryLinks.map((link) => (
            <a href={link.href} class="inline-flex items-center gap-2 border border-border-subtle px-4 py-2 font-label-sm text-label-sm uppercase text-text-muted hover:border-primary hover:text-primary transition-colors">
              <Icon name={link.icon} size={16} />
              {link.label}
            </a>
          ))}
        </div>
      </section>

      {guides.length === 0 ? (
        <div class="border border-border-subtle bg-white-pure p-12 text-center text-text-muted mb-section-gap">
          <Icon name="school" size={36} />
          <p class="font-body-md mt-4">Rehber içerikleri yakında eklenecek.</p>
        </div>
      ) : (
        <section class="mb-section-gap">
          <h2 class="font-label-sm text-label-sm text-text-muted uppercase tracking-[0.2em] mb-10">Sınav Bazlı Rehberler</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {guides.map((g) => (
              <a href={g.href} class="group border border-border-subtle bg-white-pure p-8 transition-all hover:border-black-pure block">
                <div class="aspect-video mb-6 overflow-hidden bg-surface-container flex items-center justify-center">
                  <Icon name={g.icon} size={48} className="text-text-muted" />
                </div>
                <div class="flex justify-between items-start mb-4">
                  <span class="font-label-sm text-label-sm text-text-muted uppercase">{g.name}</span>
                  <Icon name="north_east" size={14} />
                </div>
                <h3 class="font-headline-md text-headline-md mb-3">{g.title}</h3>
                <p class="font-body-md text-text-muted text-sm line-clamp-3">{g.summary}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</Layout>
