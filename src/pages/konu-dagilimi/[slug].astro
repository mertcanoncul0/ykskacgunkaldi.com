---
import Layout from "../../layouts/Layout.astro";
import { KonuDagilimiClient } from "../../components/KonuDagilimiClient";
import { getExams, getSubjects, getTopicDistributions } from "../../lib/pocketbase";
import { breadcrumbJsonLd, webPageJsonLd } from "../../lib/schema";

const { slug } = Astro.params;

const pageMap: Record<
  string,
  { title: string; metaTitle: string; description: string; examSlug: string; focusMode: "tyt" | "ayt" | "lgs" }
> = {
  tyt: {
    title: "TYT Çıkan Konular ve Konu Dağılımı",
    metaTitle: "TYT Çıkan Konular ve Konu Dağılımı | YKS Kaç Gün Kaldı",
    description:
      "TYT Türkçe, matematik, sosyal ve fen konularını yıllara göre soru dağılımı ile inceleyin; soru metni olmadan çalışma önceliği belirleyin.",
    examSlug: "yks",
    focusMode: "tyt",
  },
  ayt: {
    title: "AYT Çıkan Konular ve Konu Dağılımı",
    metaTitle: "AYT Çıkan Konular ve Konu Dağılımı | YKS Kaç Gün Kaldı",
    description:
      "AYT matematik, edebiyat, tarih, coğrafya, fizik, kimya ve biyoloji konu dağılımını yıllara göre inceleyerek alan çalışma planınızı güçlendirin.",
    examSlug: "yks",
    focusMode: "ayt",
  },
  lgs: {
    title: "LGS Konu Dağılımı",
    metaTitle: "LGS Konu Dağılımı | Yıllara Göre Soru Dağılımı",
    description:
      "LGS dersleri için konu dağılımını inceleyin, deneme ve tekrar planınızı veriye göre oluşturun.",
    examSlug: "lgs",
    focusMode: "lgs",
  },
};

const page = slug ? pageMap[slug] : undefined;
if (!page) {
  return new Response("Not found", { status: 404 });
}

const [exams, subjects, distributions] = await Promise.all([
  getExams(),
  getSubjects(),
  getTopicDistributions(),
]);

const path = `/konu-dagilimi/${slug}`;
const structuredData = [
  breadcrumbJsonLd([
    { name: "Ana Sayfa", path: "/" },
    { name: "Konu Dağılımı", path: "/konu-dagilimi" },
    { name: page.title, path },
  ]),
  webPageJsonLd({ title: page.title, description: page.description, path }),
];
---

<Layout
  title={page.metaTitle}
  description={page.description}
  path={path}
  structuredData={structuredData}
>
  <KonuDagilimiClient
    client:load
    exams={exams}
    subjects={subjects}
    distributions={distributions}
    initialExamSlug={page.examSlug}
    focusMode={page.focusMode}
    titleOverride={page.title}
    descriptionOverride={page.description}
  />
</Layout>
