---
import Layout from '../layouts/Layout.astro';
import { hubLinks } from '../lib/site';
import { Icon } from '../lib/icons';

Astro.response.status = 404;
---

<Layout
  title="Sayfa Bulunamadı (404) | YKS Kaç Gün Kaldı"
  description="Aradığınız sayfa bulunamadı. Sınav takvimi, geri sayım ve sınav hazırlık rehberlerine buradan ulaşabilirsiniz."
  noindex={true}
>
  <div class="px-margin-mobile md:px-margin-desktop">
    <div class="max-w-3xl mx-auto py-section-gap text-center">
      <Icon name="search_off" size={64} className="text-text-muted" />
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mt-6 mb-4">404</h1>
      <p class="font-headline-md text-headline-md text-black-pure mb-2">Sayfa Bulunamadı</p>
      <p class="font-body-lg text-body-lg text-text-muted mb-10 max-w-xl mx-auto">
        Aradığınız sayfa kaldırılmış, taşınmış ya da hiç var olmamış olabilir. Aramayı deneyebilir ya da aşağıdaki bağlantılardan devam edebilirsin.
      </p>

      <form action="/arama" method="get" class="flex items-center gap-3 border-b border-border-subtle focus-within:border-primary transition-colors pb-3 max-w-md mx-auto mb-12 text-left">
        <Icon name="search" size={22} className="text-primary shrink-0" />
        <input
          type="search"
          name="q"
          placeholder="Sınav, puan, konu, yazı ara…"
          class="search-input flex-1 min-w-0 bg-transparent font-body-md placeholder:text-text-muted"
        />
        <button type="submit" class="font-label-md text-label-md uppercase tracking-wide text-primary hover:opacity-70 transition-opacity">Ara</button>
      </form>

      <div class="flex flex-wrap justify-center gap-4 mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-black-pure text-white-pure px-6 py-3 font-label-md uppercase hover:bg-primary transition-colors"
        >
          <Icon name="home" size={18} />
          Ana Sayfa
        </a>
        <a
          href="/sinavlar"
          class="inline-flex items-center gap-2 border border-border-subtle px-6 py-3 font-label-md uppercase hover:bg-surface-container-high transition-colors"
        >
          <Icon name="calendar_month" size={18} />
          Sınav Takvimi
        </a>
        <a
          href="/sayac"
          class="inline-flex items-center gap-2 border border-border-subtle px-6 py-3 font-label-md uppercase hover:bg-surface-container-high transition-colors"
        >
          <Icon name="timer" size={18} />
          Sınav Sayacı
        </a>
      </div>

      <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 font-label-sm text-text-muted" aria-label="Hızlı bağlantılar">
        {hubLinks.map((l) => (
          <a href={l.href} class="hover:text-primary transition-colors uppercase tracking-wide">{l.label}</a>
        ))}
      </nav>
    </div>
  </div>
</Layout>
