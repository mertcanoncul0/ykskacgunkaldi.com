---
import Layout from '../../layouts/Layout.astro';
import { getScoreCalculatorConfig, getCalculatorFaqs, scoreCalculatorMenu } from '../../data/score-calculators';
import { ScoreCalculatorForm } from '../../components/ScoreCalculatorForm';
import { CalcExamCountdown } from '../../components/CalcExamCountdown';
import { site } from '../../lib/site';
import { getExams } from '../../lib/pocketbase';
import { Icon } from '../../lib/icons';

const { slug } = Astro.params;
const config = getScoreCalculatorConfig(slug as string);

if (!config) {
  return new Response('Not found', { status: 404 });
}

const faqs = getCalculatorFaqs(slug as string);
const others = scoreCalculatorMenu.filter((c) => c.slug !== slug);

const exams = await getExams();
const activeExam = exams.find((e) => e.slug === config.kind) || exams.find((e) => e.slug === 'yks');
const activeSession = activeExam?.sessions?.find((s: any) => s.slug === slug);

const targetDate = activeSession?.targetDate || activeExam?.targetDate || new Date().toISOString();
const targetLabel = activeSession?.countdownLabel || activeExam?.countdownLabel || "Sınava Kalan Süre";

const pageUrl = `${site.url}/puan-hesaplama/${slug}`;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Puan Hesaplama', item: `${site.url}/puan-hesaplama/yks` },
      { '@type': 'ListItem', position: 3, name: config.title, item: pageUrl },
    ],
  },
  ...(faqs.length > 0
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: faqs.map((f) => ({
            '@type': 'Question',
            name: f.q,
            acceptedAnswer: { '@type': 'Answer', text: f.a },
          })),
        },
      ]
    : []),
];
---

<Layout
  title={config.metaTitle || `${config.title} | Puan Hesaplama`}
  description={config.description || "Sınav puanı hesaplama aracı."}
  structuredData={structuredData}
>
  <div class="px-margin-mobile md:px-margin-desktop">
    <div class="max-w-container-max mx-auto py-section-gap">
      <nav class="flex items-center gap-2 mb-8 font-label-sm text-text-muted" aria-label="Breadcrumb">
        <a class="hover:text-primary transition-colors" href="/">Ana Sayfa</a>
        <Icon name="chevron_right" size={16} />
        <a class="hover:text-primary transition-colors" href="/puan-hesaplama/yks">Puan Hesaplama</a>
        <Icon name="chevron_right" size={16} />
        <span class="text-on-surface line-clamp-1" aria-current="page">{config.title}</span>
      </nav>

      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-2 mb-6">
          <span class="inline-flex items-center gap-2 bg-black-pure text-white-pure px-3 py-1 font-label-sm text-label-sm uppercase">
            <Icon name="calculate" size={16} />
            Güncel Katsayılar
          </span>
          <span class="inline-flex items-center gap-2 border border-border-subtle px-3 py-1 font-label-sm text-label-sm uppercase text-text-muted">
            <Icon name="verified" size={16} />
            ÖSYM/MEB Kılavuzu
          </span>
        </div>
        <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-4">{config.title}</h1>
        <p class="font-body-lg text-body-lg text-text-muted max-w-2xl">{config.lead}</p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">
        <div class="lg:col-span-8 flex flex-col gap-8">
          <ScoreCalculatorForm client:load config={config} />

          <article class="border border-border-subtle bg-white-pure p-8">
            <h2 class="flex items-center gap-2 font-headline-md text-headline-md text-primary mb-4">
              <Icon name="info" />
              Nasıl Hesaplanır?
            </h2>
            <p class="font-body-md text-body-md text-text-muted leading-relaxed">{config.formulaNote}</p>
          </article>

          {faqs.length > 0 && (
            <section class="border border-border-subtle bg-white-pure p-8" aria-labelledby="calc-faq-title">
              <h2 id="calc-faq-title" class="flex items-center gap-2 font-headline-md text-headline-md text-primary mb-6">
                <Icon name="help" />
                Sıkça Sorulan Sorular
              </h2>
              <div class="flex flex-col">
                {faqs.map((f) => (
                  <details class="group border-b border-border-subtle py-4 last:border-0">
                    <summary class="flex items-center justify-between gap-4 cursor-pointer font-label-md text-label-md text-on-surface list-none [&::-webkit-details-marker]:hidden">
                      {f.q}
                      <Icon name="expand_more" className="text-text-muted shrink-0 transition-transform group-open:rotate-180" />
                    </summary>
                    <p class="font-body-md text-body-md text-text-muted mt-4 leading-relaxed">{f.a}</p>
                  </details>
                ))}
              </div>
            </section>
          )}

          <section class="border border-border-subtle bg-white-pure p-8" aria-labelledby="calc-related-title">
            <h2 id="calc-related-title" class="flex items-center gap-2 font-headline-md text-headline-md text-primary mb-6">
              <Icon name="explore" />
              İlgili Sayfalar
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <a href="/blog" class="group flex items-start gap-4 border border-border-subtle p-4 hover:border-black-pure transition-colors">
                <Icon name="article" className="text-text-muted" />
                <div>
                  <strong class="block font-label-md text-on-surface group-hover:text-primary transition-colors">Rehberler &amp; Blog</strong>
                  <span class="font-body-md text-body-md text-text-muted">Sınavlara dair detaylı bilgilere ulaş.</span>
                </div>
              </a>
            </div>
          </section>
        </div>

        <aside class="lg:col-span-4 flex flex-col gap-6">
          <CalcExamCountdown
            client:load
            targetDate={targetDate}
            label={targetLabel}
            href="/sayac"
            isEstimated={true}
          />
          <div class="border border-border-subtle bg-white-pure p-6">
            <h3 class="font-headline-md text-headline-md text-primary mb-4">Diğer Araçlar</h3>
            <ul class="flex flex-col gap-1">
              {others.map((o) => (
                <li>
                  <a class="flex items-center gap-2 py-2 font-body-md text-body-md text-on-surface hover:text-primary transition-colors" href={`/puan-hesaplama/${o.slug}`}>
                    <Icon name={o.icon} size={18} className="text-text-muted" />
                    {o.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="border border-border-subtle bg-white-pure p-6">
            <h3 class="font-headline-md text-headline-md text-primary mb-4">Bilgi</h3>
            <p class="font-body-md text-body-md text-text-muted leading-relaxed">
              Hesaplanan puanlar tahmini olup, ÖSYM/MEB'in uyguladığı standart
              sapma ve test ortalamalarına göre gerçek sınav sonucunda ufak
              farklılıklar gösterebilir.
            </p>
          </div>

          {config.sources?.length > 0 && (
            <div class="border border-border-subtle bg-white-pure p-6">
              <h3 class="font-headline-md text-headline-md text-primary mb-4">Kaynaklar</h3>
              <ul class="flex flex-col gap-1">
                {config.sources.map((s) => (
                  <li>
                    <a class="block py-2 font-body-md text-body-md text-primary underline hover:text-text-muted transition-colors" href={s.url} target="_blank" rel="noopener noreferrer">
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </div>
  </div>
</Layout>
