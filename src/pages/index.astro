---
import Layout from '../layouts/Layout.astro';
import { HomeClient } from '../components/HomeClient';
import { getHomeSeo } from '../lib/home-seo';
import { getExams, getFaqs, getSettings, getPosts } from '../lib/pocketbase';

const [exams, faqs, settings, posts] = await Promise.all([
  getExams(),
  getFaqs(),
  getSettings(),
  getPosts(),
]);

const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '').trim();
const selectedExamSlug = Astro.url.searchParams.get('sinav');
const homeSeo = getHomeSeo(settings, exams, selectedExamSlug);

const faqJsonLd = faqs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: stripHtml(f.answer),
        },
      })),
    }
  : null;
---

<Layout
  title={homeSeo.title}
  description={homeSeo.description}
  path={homeSeo.canonicalPath}
  structuredData={faqJsonLd ? [faqJsonLd] : []}
>
  <HomeClient
    client:load
    exams={exams}
    faqs={faqs}
    posts={posts.slice(0, 3)}
    defaultSeo={settings}
    initialSelectionSlug={homeSeo.selectionSlug}
  />
</Layout>
