---
import { scoreCalculatorMenu } from "../data/score-calculators";
import { homeSelectionLandingPaths } from "../data/exam-landing-pages";
import { site, socialLinks } from "../lib/site";
import { Icon } from "../lib/icons";
import { readUser } from "../lib/auth-server";

type HeaderExam = {
  slug: string;
  name: string;
};

interface Props {
  exams?: HeaderExam[];
}

const { exams = [] } = Astro.props;
const user = readUser(Astro.cookies);
const displayName = user?.name?.trim() || user?.email?.split("@")[0] || "Hesabım";
const path = Astro.url.pathname;

const examIcons: Record<string, string> = {
  yks: "school",
  lgs: "menu_book",
  dgs: "trending_up",
  kpss: "work",
  ales: "psychology",
  msu: "military_tech",
};

const examDescriptions: Record<string, string> = {
  yks: "Yükseköğretim Kurumları Sınavı hazırlık materyalleri ve detayları.",
  lgs: "Liselere Geçiş Sistemi denemeleri, çıkmış sorular ve konu anlatımları.",
  dgs: "Dikey Geçiş Sınavı ile lisans tamamlama rehberi ve dokümanları.",
  kpss: "Kamu Personeli Seçme Sınavı memurluk rehberi ve hazırlık testleri.",
  ales: "Akademik Personel ve Lisansüstü Eğitim Giriş Sınavı kaynakları.",
  msu: "Milli Savunma Üniversitesi askeri öğrenci seçme sınavı içerikleri.",
};

const examLabels: Record<string, string> = {
  yks: "YKS (TYT - AYT - YDT)",
};

const mainLinks = [
  { to: "/rehberler", label: "Sınav Rehberi" },
  { to: "/hakkimizda", label: "Hakkımızda" },
] as const;

const popularSearches = [
  "YKS kaç gün kaldı",
  "TYT puan hesaplama",
  "AYT konu dağılımı",
  "YKS çalışma programı",
  "Deneme net takip",
] as const;

const searchQuickLinks = [
  { label: "Sınav Takvimi", href: "/sinavlar", icon: "calendar_month" },
  { label: "Puan Hesaplama", href: "/puan-hesaplama/yks", icon: "calculate" },
  { label: "Blog & Rehber", href: "/blog", icon: "article" },
  { label: "Sınav Rehberi", href: "/rehberler", icon: "school" },
] as const;

const socialSvg: Record<string, string> = {
  facebook: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>',
  twitter: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>',
  instagram: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
  tiktok: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 1 1-2-2.75v-3.5a6.33 6.33 0 1 0 5.45 6.25V8.72a8.16 8.16 0 0 0 4.77 1.52V6.69Z"/></svg>',
  youtube: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/></svg>',
};

const underline =
  "relative after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-full after:origin-left after:bg-primary after:transition-transform after:duration-300 after:ease-out after:content-['']";
const navClass = (active: boolean) =>
  `${underline} font-label-md text-label-md transition-colors duration-200 ${
    active
      ? "text-primary font-bold after:scale-x-100"
      : "text-text-muted hover:text-primary after:scale-x-0 hover:after:scale-x-100"
  }`;
const triggerClass = (active: boolean) =>
  `${underline} flex items-center gap-1 font-label-md text-label-md transition-colors duration-200 ${
    active
      ? "text-primary font-bold after:scale-x-100"
      : "text-text-muted hover:text-primary after:scale-x-0 hover:after:scale-x-100"
  }`;
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-surface-container-lowest border-b border-border-subtle"
  data-site-header
>
  <nav class="relative flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-4 max-w-[1440px] mx-auto h-16">
    <div class="flex items-center gap-3">
      <button
        type="button"
        class="hidden hdr:inline-flex h-10 w-10 items-center justify-center text-text-muted hover:text-primary transition-colors duration-200"
        aria-label="Menüyü aç"
        aria-expanded="false"
        data-sidebar-toggle
      >
        <span data-sidebar-open-icon><Icon name="menu" size={22} /></span>
        <span class="hidden" data-sidebar-close-icon><Icon name="close" size={22} /></span>
      </button>
      <a
        href="/"
        class="whitespace-nowrap font-display-lg text-[22px] sm:text-[24px] leading-none tracking-normal text-primary uppercase font-semibold transition-opacity hover:opacity-70"
        aria-label="Ana sayfa"
      >
        {site.name}
      </a>
    </div>

    <div class="hidden hdr:flex flex-1 items-center justify-center gap-8">
      <div class="group relative flex h-16 items-center">
        <button
          type="button"
          class={triggerClass(path.startsWith("/sinavlar") || path.endsWith("-kac-gun-kaldi"))}
          aria-haspopup="true"
          aria-controls="header-exams-menu"
        >
          Sınavlar
          <Icon name="expand_more" size={18} />
        </button>
        <div
          id="header-exams-menu"
          class="absolute top-16 left-1/2 hidden w-[680px] max-w-[calc(100vw-2rem)] -translate-x-1/2 border border-border-subtle bg-surface-container-lowest z-40 group-hover:block group-focus-within:block"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 p-2">
            {exams.map((exam) => (
              <a
                href={homeSelectionLandingPaths[exam.slug] || `/?sinav=${exam.slug}`}
                class="flex items-start gap-3 p-3 hover:bg-surface-container-high transition-colors"
              >
                <Icon name={examIcons[exam.slug] || "edit_document"} size={20} className="text-primary mt-0.5 shrink-0" />
                <span class="flex flex-col">
                  <strong class="font-label-md text-label-md text-primary">{examLabels[exam.slug] || exam.name}</strong>
                  <small class="font-body-md text-text-muted text-sm">{examDescriptions[exam.slug] || "Sınav detayları"}</small>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="group relative flex h-16 items-center">
        <button
          type="button"
          class={triggerClass(path.startsWith("/puan-hesaplama"))}
          aria-haspopup="true"
          aria-controls="header-calc-menu"
        >
          Puan Hesaplama
          <Icon name="expand_more" size={18} />
        </button>
        <div
          id="header-calc-menu"
          class="absolute top-16 left-1/2 hidden w-64 max-w-[calc(100vw-2rem)] -translate-x-1/2 border border-border-subtle bg-surface-container-lowest z-40 group-hover:block group-focus-within:block"
        >
          <div class="flex flex-col p-2">
            {scoreCalculatorMenu?.map((item) => (
              <a
                href={`/puan-hesaplama/${item.slug}`}
                class="flex items-center gap-3 p-3 hover:bg-surface-container-high transition-colors font-label-md text-label-md"
              >
                <Icon name={item.icon} size={20} className="text-primary shrink-0" />
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/blog" class={navClass(path === "/blog" || path.startsWith("/blog/"))} aria-current={path === "/blog" || path.startsWith("/blog/") ? "page" : undefined}>Blog</a>
      {mainLinks.map((link) => (
        <a href={link.to} class={navClass(path.startsWith(link.to))} aria-current={path.startsWith(link.to) ? "page" : undefined}>{link.label}</a>
      ))}
    </div>

    <div class="hidden hdr:flex items-center gap-1">
      <div class="hidden hdrwide:flex items-center gap-0.5 mr-2">
        {socialLinks.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="inline-flex h-9 w-9 items-center justify-center text-text-muted hover:text-primary transition-colors duration-200" aria-label={s.label} set:html={socialSvg[s.icon]} />
        ))}
      </div>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center text-text-muted hover:text-primary transition-colors duration-200"
        aria-label="Ara"
        aria-expanded="false"
        aria-controls="header-search-panel"
        data-search-open
      >
        <Icon name="search" size={20} />
      </button>
    </div>

    <button
      type="button"
      class="hdr:hidden inline-flex h-10 w-10 items-center justify-center border border-primary text-primary"
      aria-label="Menüyü aç"
      aria-expanded="false"
      aria-controls="header-mobile-menu"
      data-mobile-toggle
    >
      <span data-mobile-open-icon><Icon name="menu" size={22} /></span>
      <span class="hidden" data-mobile-close-icon><Icon name="close" size={22} /></span>
    </button>
  </nav>

  <div
    id="header-search-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Arama"
    class="fixed inset-0 z-[60] hidden bg-surface-container-lowest/95 backdrop-blur-md"
    data-search-panel
  >
    <div class="flex h-full flex-col">
      <div class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop py-5 flex items-center justify-between">
        <a href="/" class="font-display-lg text-[22px] leading-none tracking-normal text-primary uppercase font-semibold">{site.name}</a>
        <button type="button" aria-label="Aramayı kapat" class="group inline-flex items-center gap-2 text-text-muted hover:text-primary transition-colors" data-search-close>
          <span class="hidden sm:inline font-label-sm uppercase tracking-widest">Kapat</span>
          <span class="inline-flex h-11 w-11 items-center justify-center border border-border-subtle group-hover:border-primary transition-colors">
            <Icon name="close" size={22} />
          </span>
        </button>
      </div>

      <div class="flex-1 flex items-start md:items-center overflow-y-auto">
        <div class="w-full max-w-[1000px] mx-auto px-margin-mobile md:px-margin-desktop py-8 md:-mt-16">
          <form action="/arama" method="get" data-search-form>
            <label class="block font-label-sm uppercase tracking-[0.3em] text-text-muted mb-5">Ne arıyorsun?</label>
            <div class="flex items-center gap-4 border-b border-border-subtle focus-within:border-primary transition-colors duration-200 pb-4">
              <Icon name="search" size={32} className="text-primary shrink-0" />
              <input
                type="search"
                name="q"
                placeholder="Sınav, puan, konu, yazı..."
                class="search-input flex-1 min-w-0 bg-transparent font-display-lg text-3xl md:text-5xl leading-tight placeholder:text-text-muted/40"
                data-search-input
              />
            </div>
          </form>

          <div class="mt-10 hidden" data-recent-wrap>
            <div class="flex items-center justify-between mb-4">
              <p class="font-label-sm uppercase tracking-widest text-text-muted">Son aramalar</p>
              <button type="button" class="font-label-sm text-text-muted hover:text-primary transition-colors" data-clear-recent>Temizle</button>
            </div>
            <div class="flex flex-wrap gap-3" data-recent-list></div>
          </div>

          <div class="mt-10">
            <p class="font-label-sm uppercase tracking-widest text-text-muted mb-4">Popüler aramalar</p>
            <div class="flex flex-wrap gap-3">
              {popularSearches.map((q) => (
                <a href={`/arama?q=${encodeURIComponent(q)}`} data-search-chip class="px-4 py-2 border border-border-subtle text-text-muted hover:border-primary hover:text-primary transition-colors font-label-md text-label-md">{q}</a>
              ))}
            </div>
          </div>

          <div class="mt-12">
            <p class="font-label-sm uppercase tracking-widest text-text-muted mb-4">Hızlı erişim</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-border-subtle border border-border-subtle">
              {searchQuickLinks.map((link) => (
                <a href={link.href} class="group flex items-center gap-4 bg-surface-container-lowest p-5 hover:bg-surface-container-high transition-colors">
                  <span class="inline-flex h-11 w-11 items-center justify-center bg-primary text-on-primary shrink-0 transition-transform duration-300 group-hover:scale-105">
                    <Icon name={link.icon} size={22} />
                  </span>
                  <span class="flex flex-col">
                    <span class="font-label-md text-label-md text-primary">{link.label}</span>
                    <span class="font-body-md text-text-muted text-sm">Hemen incele</span>
                  </span>
                  <Icon name="arrow_forward" size={20} className="ml-auto text-text-muted group-hover:text-primary transition-colors" />
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    id="header-mobile-menu"
    class="hdr:hidden hidden absolute left-0 right-0 top-16 z-40 max-h-[calc(100vh-4rem)] overflow-y-auto border-b border-border-subtle bg-surface-container-lowest"
    data-mobile-menu
  >
    <div class="px-margin-mobile py-5">
      <form action="/arama" method="get" class="flex items-center gap-3 border-b border-border-subtle focus-within:border-primary transition-colors pb-3 mb-5" data-search-form>
        <Icon name="search" size={20} className="text-primary" />
        <input type="search" name="q" placeholder="Sınav, rehber veya yazı ara..." class="search-input flex-1 bg-transparent font-body-md placeholder:text-text-muted" />
      </form>

      <div class="border-b border-border-subtle pb-5">
        <p class="font-label-sm text-label-sm uppercase tracking-widest text-text-muted mb-3">Sınavlar</p>
        <div class="grid grid-cols-1 gap-1">
          {exams.map((exam) => (
            <a href={homeSelectionLandingPaths[exam.slug] || `/?sinav=${exam.slug}`} class="flex items-center justify-between gap-3 px-3 py-3 font-label-md text-label-md text-primary hover:bg-surface-container-high">
              <span>{examLabels[exam.slug] || exam.name}</span>
              <Icon name="chevron_right" size={18} className="text-text-muted" />
            </a>
          ))}
        </div>
      </div>

      <div class="border-b border-border-subtle py-5">
        <p class="font-label-sm text-label-sm uppercase tracking-widest text-text-muted mb-3">Puan Hesaplama</p>
        <div class="grid grid-cols-1 gap-1">
          {scoreCalculatorMenu?.map((item) => (
            <a href={`/puan-hesaplama/${item.slug}`} class="flex items-center justify-between gap-3 px-3 py-3 font-label-md text-label-md text-primary hover:bg-surface-container-high">
              <span>{item.label}</span>
              <Icon name={item.icon} size={18} className="text-text-muted" />
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-1 gap-1 pt-5">
        <a href="/blog" class="px-3 py-3 font-label-md text-label-md text-primary hover:bg-surface-container-high">Blog</a>
        {mainLinks.map((link) => (
          <a href={link.to} class="px-3 py-3 font-label-md text-label-md text-primary hover:bg-surface-container-high">{link.label}</a>
        ))}
        {user ? (
          <div class="mt-2 border border-border-subtle">
            <a href="/hesap" class="flex items-center gap-3 px-3 py-3 border-b border-border-subtle hover:bg-surface-container-high">
              <span class="inline-flex h-8 w-8 items-center justify-center bg-primary text-on-primary text-xs font-semibold uppercase">{displayName.charAt(0)}</span>
              <span class="flex flex-col min-w-0">
                <span class="font-label-md text-label-md text-primary truncate">{displayName}</span>
                <span class="font-body-md text-xs text-text-muted truncate">{user.email}</span>
              </span>
            </a>
            <a href="/hesap" class="w-full flex items-center gap-2 px-3 py-3 font-label-md text-label-md text-primary hover:bg-surface-container-high">
              <Icon name="account" size={18} />
              <span>Hesabım</span>
            </a>
            <form method="POST" action="/api/auth/logout">
              <button type="submit" class="w-full flex items-center gap-2 px-3 py-3 text-left font-label-md text-label-md text-primary hover:bg-surface-container-high border-t border-border-subtle">
                <Icon name="logout" size={18} />
                <span>Çıkış Yap</span>
              </button>
            </form>
          </div>
        ) : (
          <div class="mt-2 grid grid-cols-2 gap-2">
            <a href="/giris" class="flex items-center justify-center gap-2 border border-border-subtle px-3 py-3 font-label-md text-label-md text-primary hover:border-primary">
              <Icon name="login" size={18} />
              <span>Giriş</span>
            </a>
            <a href="/kayit" class="flex items-center justify-center gap-2 bg-primary text-on-primary px-3 py-3 font-label-md text-label-md">
              <Icon name="person_add" size={18} />
              <span>Kayıt</span>
            </a>
          </div>
        )}
      </div>

      <div class="flex items-center gap-2 pt-5 mt-5 border-t border-border-subtle">
        {socialLinks.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="inline-flex h-10 w-10 items-center justify-center border border-border-subtle text-text-muted hover:border-primary hover:text-primary transition-colors" aria-label={s.label} set:html={socialSvg[s.icon]} />
        ))}
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-site-header]");
    if (!header) return;

    const $ = (selector) => header.querySelector(selector);
    const searchPanel = $("[data-search-panel]");
    const searchOpen = $("[data-search-open]");
    const searchClose = $("[data-search-close]");
    const searchInput = $("[data-search-input]");
    const mobileMenu = $("[data-mobile-menu]");
    const mobileToggle = $("[data-mobile-toggle]");
    const sidebarToggle = $("[data-sidebar-toggle]");
    const recentWrap = $("[data-recent-wrap]");
    const recentList = $("[data-recent-list]");
    const clearRecent = $("[data-clear-recent]");
    const recentKey = "recent-searches";

    const getRecent = () => {
      try {
        return JSON.parse(localStorage.getItem(recentKey) || "[]").filter(Boolean).slice(0, 5);
      } catch {
        return [];
      }
    };
    const setRecent = (items) => {
      try {
        localStorage.setItem(recentKey, JSON.stringify(items.slice(0, 5)));
      } catch {}
    };
    const addRecent = (query) => {
      const q = String(query || "").trim();
      if (!q) return;
      setRecent([q, ...getRecent().filter((item) => item !== q)]);
    };
    const renderRecent = () => {
      if (!recentWrap || !recentList) return;
      const items = getRecent();
      recentWrap.classList.toggle("hidden", items.length === 0);
      recentList.textContent = "";
      for (const item of items) {
        const a = document.createElement("a");
        a.href = `/arama?q=${encodeURIComponent(item)}`;
        a.className = "inline-flex items-center gap-2 px-4 py-2 border border-border-subtle text-text-muted hover:border-primary hover:text-primary transition-colors font-label-md text-label-md";
        a.textContent = item;
        a.addEventListener("click", () => addRecent(item));
        recentList.append(a);
      }
    };

    const setSearchOpen = (open) => {
      searchPanel?.classList.toggle("hidden", !open);
      searchOpen?.setAttribute("aria-expanded", String(open));
      document.body.style.overflow = open ? "hidden" : "";
      if (open) {
        renderRecent();
        window.setTimeout(() => searchInput?.focus?.(), 0);
      }
    };
    const setMobileOpen = (open) => {
      mobileMenu?.classList.toggle("hidden", !open);
      mobileToggle?.setAttribute("aria-expanded", String(open));
      mobileToggle?.querySelector("[data-mobile-open-icon]")?.classList.toggle("hidden", open);
      mobileToggle?.querySelector("[data-mobile-close-icon]")?.classList.toggle("hidden", !open);
    };
    const syncSidebar = () => {
      const open = document.body.classList.contains("sidebar-open");
      sidebarToggle?.setAttribute("aria-expanded", String(open));
      sidebarToggle?.setAttribute("aria-label", open ? "Menüyü kapat" : "Menüyü aç");
      sidebarToggle?.querySelector("[data-sidebar-open-icon]")?.classList.toggle("hidden", open);
      sidebarToggle?.querySelector("[data-sidebar-close-icon]")?.classList.toggle("hidden", !open);
    };

    searchOpen?.addEventListener("click", () => setSearchOpen(true));
    searchClose?.addEventListener("click", () => setSearchOpen(false));
    searchPanel?.addEventListener("mousedown", (event) => {
      if (event.target === searchPanel) setSearchOpen(false);
    });
    mobileToggle?.addEventListener("click", () => {
      setMobileOpen(mobileMenu?.classList.contains("hidden"));
    });
    sidebarToggle?.addEventListener("click", () => {
      const next = !document.body.classList.contains("sidebar-open");
      document.body.classList.toggle("sidebar-open", next);
      try {
        localStorage.setItem("sidebar-open", String(next));
      } catch {}
      syncSidebar();
    });
    clearRecent?.addEventListener("click", () => {
      setRecent([]);
      renderRecent();
    });
    header.querySelectorAll("[data-search-form]").forEach((form) => {
      form.addEventListener("submit", () => {
        const value = new FormData(form).get("q");
        addRecent(value);
      });
    });
    header.querySelectorAll("[data-search-chip]").forEach((chip) => {
      chip.addEventListener("click", () => addRecent(chip.textContent));
    });
    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setSearchOpen(false);
        setMobileOpen(false);
      }
    });
    syncSidebar();
