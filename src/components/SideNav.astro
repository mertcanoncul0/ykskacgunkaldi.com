---
// Persistent left sidebar — drawn identically (4 items: Geri Sayım /
// Popüler Yazılar / Sınav Rehberi / İlanlar) on every single new_ui mockup
// (ana_sayfa, blog listesi, blog detayı, sınav takvimi, ilanlar, popüler
// yazılar, rehberlik). This is the site's global secondary navigation,
// rendered once from Layout.astro on every page — not just a "hub" subset.
//
// Active state follows the dominant mockup pattern (5 of 6 mockups): a
// full bg-primary fill on the active row. Active item is derived from the
// real route so it's always correct, instead of copying each mockup's
// occasionally-mismatched "active" choice.
import type { Exam } from '../lib/api';
import { Icon } from '../lib/icons';
import { socialLinks } from '../lib/site';
import { readUser } from '../lib/auth-server';

const user = readUser(Astro.cookies);
const displayName = user?.name?.trim() || user?.email?.split('@')[0] || 'Hesabım';

// lucide 1.x marka ikonlarını taşımadığı için inline SVG (Header'daki
// SocialIcon ile aynı yollar).
const socialSvg: Record<string, string> = {
  facebook: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>',
  twitter: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>',
  instagram: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
  youtube: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/></svg>',
};

interface Props {
  exams?: Exam[];
}

const { exams = [] } = Astro.props;
const { pathname } = Astro.url;

const items = [
  { key: 'yks-kac-gun-kaldi', href: '/yks-kac-gun-kaldi', label: 'YKS Sayacı', icon: 'timer' },
  { key: '2027-yks-takvimi', href: '/2027-yks-takvimi', label: 'YKS Takvimi', icon: 'calendar_month' },
  { key: 'puan-hesaplama', href: '/puan-hesaplama/yks', label: 'Puan Hesaplama', icon: 'calculate' },
  { key: 'rehberler', href: '/rehberler', label: 'Sınav Rehberi', icon: 'school' },
] as const;

function isActive(href: string) {
  if (href === '/yks-kac-gun-kaldi') return pathname === '/' || pathname.endsWith('-kac-gun-kaldi') || pathname.startsWith('/sayac') || pathname.startsWith('/sinavlar');
  if (href === '/puan-hesaplama/yks') return pathname.startsWith('/puan-hesaplama');
  return pathname.startsWith(href);
}

// Sidebar eyebrow ("YKS 2027" gibi) önceden sabit kodlanmıştı ve gerçek YKS
// tarihinden (2027) bağımsız, her yıl elle güncellenmesi gereken bir
// "2026" değeriydi — gerçek veriyle çelişen, yanlış bir bilgiydi. Artık
// gerçek `yks` sınavının countdownLabel alanından türetiliyor.
const yksExam = exams.find((e) => e.slug === 'yks');
const eyebrowLabel = yksExam?.countdownLabel || 'Hazırlık Rehberi';
---

<aside class="app-sidebar hidden hdr:flex flex-col fixed left-0 top-16 h-[calc(100vh-4rem)] w-64 bg-surface border-r border-border-subtle py-8 z-40 overflow-y-auto">
  <div class="px-6 mb-10">
    <h2 class="font-headline-md text-headline-md text-primary mb-1">{eyebrowLabel}</h2>
    <p class="font-label-sm text-label-sm text-text-muted uppercase tracking-widest">Hazırlık Rehberi</p>
  </div>
  <nav class="flex flex-col" aria-label="Rehber menüsü">
    {items.map((item) => {
      const active = isActive(item.href);
      return (
        <a
          href={item.href}
          class={active
            ? 'bg-primary text-on-primary font-bold px-6 py-4 flex items-center gap-4 transition-opacity'
            : 'text-on-surface-variant hover:bg-surface-container-high px-6 py-4 flex items-center gap-4 transition-colors'}
          aria-current={active ? 'page' : undefined}
        >
          <Icon name={item.icon} strokeWidth={active ? 2.25 : 1.75} />
          <span class="font-label-md text-label-md">{item.label}</span>
        </a>
      );
    })}
  </nav>

  {/* Alt blok: hesap + sosyal medya (header'dan buraya taşındı) */}
  <div class="mt-auto px-6 pt-6 border-t border-border-subtle">
    {/* Hesap */}
    {user ? (
      <div class="mb-6">
        <a href="/hesap" class="flex items-center gap-3 mb-3 group">
          <span class="inline-flex h-9 w-9 items-center justify-center bg-primary text-on-primary text-sm font-bold uppercase">{displayName.charAt(0)}</span>
          <span class="flex flex-col min-w-0">
            <span class="font-label-md text-label-md text-primary truncate group-hover:underline underline-offset-4">{displayName}</span>
            <span class="font-body-md text-xs text-text-muted truncate">{user.email}</span>
          </span>
        </a>
        <div class="grid grid-cols-2 gap-2">
          <a href="/hesap" class="flex items-center justify-center gap-2 border border-border-subtle px-3 py-2.5 text-text-muted hover:border-primary hover:text-primary transition-colors font-label-md text-label-md">
            <Icon name="account" size={18} />
            <span>Hesabım</span>
          </a>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="w-full flex items-center justify-center gap-2 border border-border-subtle px-3 py-2.5 text-text-muted hover:border-primary hover:text-primary transition-colors font-label-md text-label-md">
              <Icon name="logout" size={18} />
              <span>Çıkış</span>
            </button>
          </form>
        </div>
      </div>
    ) : (
      <div class="mb-6 grid grid-cols-2 gap-2">
        <a href="/giris" class="flex items-center justify-center gap-2 border border-border-subtle px-3 py-2.5 text-text-muted hover:border-primary hover:text-primary transition-colors font-label-md text-label-md">
          <Icon name="login" size={18} />
          <span>Giriş</span>
        </a>
        <a href="/kayit" class="flex items-center justify-center gap-2 bg-primary text-on-primary px-3 py-2.5 hover:opacity-90 transition-opacity font-label-md text-label-md">
          <Icon name="person_add" size={18} />
          <span>Kayıt</span>
        </a>
      </div>
    )}

    {/* Sosyal medya — yalnızca <1420px (≥1420'de header'da gösterilir) */}
    <div class="hdrwide:hidden">
      <p class="font-label-sm text-label-sm text-text-muted uppercase tracking-widest mb-3">Takip Et</p>
      <div class="flex items-center gap-2">
        {socialLinks.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            class="inline-flex h-10 w-10 items-center justify-center border border-border-subtle text-text-muted hover:border-primary hover:text-primary transition-colors"
            set:html={socialSvg[s.icon]}
          />
        ))}
      </div>
    </div>
  </div>
</aside>
