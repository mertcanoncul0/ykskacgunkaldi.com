---
import { Icon } from "../lib/icons";
import { getCountdown } from "../lib/countdown";

interface Props {
  targetDate: string;
  label: string;
  isEstimated?: boolean;
  fullWidth?: boolean;
}

const { targetDate, label, isEstimated = false, fullWidth = false } = Astro.props;
const remaining = getCountdown(targetDate);
const isPast = remaining.isPast;
const units = [
  { key: "days", value: remaining.days, label: "GÜN" },
  { key: "hours", value: remaining.hours, label: "SAAT" },
  { key: "minutes", value: remaining.minutes, label: "DAKİKA" },
  { key: "seconds", value: remaining.seconds, label: "SANİYE" },
];
const [dayUnit, ...timeUnits] = units;
const liveSummary = isPast
  ? `${label}: geri sayım tamamlandı.`
  : `${label}: ${remaining.days} gün ${remaining.hours} saat ${remaining.minutes} dakika ${remaining.seconds} saniye kaldı.`;
---

<section class="w-full" aria-labelledby="countdown-title">
  <div class:list={[
    "w-full overflow-hidden border-2 border-black-pure bg-white-pure",
    fullWidth ? "" : "max-w-5xl mx-auto",
  ]}>
    <div class="grid min-h-[72px] grid-cols-1 border-b-2 border-black-pure bg-black-pure text-on-primary md:grid-cols-[1fr_auto]">
      <h2 id="countdown-title" class="flex items-center gap-3 px-5 py-4 font-label-md text-label-md uppercase md:px-7">
        <span class="inline-flex h-9 w-9 items-center justify-center border border-white-pure/50">
          <Icon name="timer" size={18} />
        </span>
        {label}
      </h2>
      {isEstimated && !isPast && (
        <span class="flex items-center gap-2 border-t border-white-pure/25 px-5 py-3 font-label-sm text-label-sm uppercase md:border-l md:border-t-0 md:px-6">
          <Icon name="info" size={15} />
          Tahmini tarih
        </span>
      )}
    </div>

    {isPast ? (
      <div class="flex flex-col items-center gap-3 bg-white-pure p-8 text-center md:p-12">
        <Icon name="task_alt" size={40} className="text-primary" />
        <span class="font-headline-md text-headline-md text-primary uppercase">Tamamlandı</span>
        <span class="font-body-md text-body-md text-text-muted">Bu sınav oturumu için geri sayım sona erdi.</span>
      </div>
    ) : (
      <div
        class="grid grid-cols-1 bg-white-pure md:grid-cols-[1.2fr_1fr]"
        role="timer"
        aria-live="off"
        aria-label={liveSummary}
        data-countdown
        data-target={targetDate}
        data-label={label}
      >
        <div aria-hidden="true" class="flex min-h-60 flex-col justify-between bg-black-pure p-6 text-on-primary sm:p-8 md:min-h-72 md:p-10">
          <span class="font-label-sm text-label-sm uppercase text-white-pure/70">Ana sayaç</span>
          <div>
            <span class="block font-display-lg text-[76px] leading-none tracking-normal sm:text-[92px] md:text-[112px] tabular-nums" data-countdown-unit="days">
              {String(dayUnit.value).padStart(2, "0")}
            </span>
            <span class="mt-3 block font-headline-md text-headline-md uppercase tracking-normal">Gün kaldı</span>
          </div>
        </div>

        <div class="grid grid-cols-3 border-t-2 border-black-pure md:border-l-2 md:border-t-0">
          {timeUnits.map((u) => (
            <div aria-hidden="true" class="flex min-h-36 flex-col items-center justify-center border-r border-border-subtle bg-surface-container-low px-3 py-7 text-center last:border-r-0 md:min-h-72 md:px-4 md:py-10">
              <span class="font-display-lg text-[44px] leading-none tracking-normal tabular-nums sm:text-[56px] md:text-[66px]" data-countdown-unit={u.key}>
                {String(u.value).padStart(2, "0")}
              </span>
              <span class="mt-4 font-label-sm text-label-sm uppercase text-text-muted">{u.label}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {isEstimated && !isPast && (
      <div class="flex items-start gap-3 border-t-2 border-black-pure bg-white-pure px-5 py-4 font-label-sm text-label-sm text-text-muted md:px-7">
        <Icon name="info" size={16} className="mt-0.5 shrink-0" />
        <span>Tarih henüz resmi olarak açıklanmamış olup, tahmini bir tarihtir.</span>
      </div>
    )}
  </div>
</section>

<script is:inline>
  (() => {
    if (window.__staticCountdownReady) return;
    window.__staticCountdownReady = true;

    const pad = (value) => String(value).padStart(2, "0");
    const update = (root) => {
      const target = new Date(root.dataset.target || "").getTime();
      if (!Number.isFinite(target)) return;
      const diff = Math.max(target - Date.now(), 0);
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      const values = { days, hours, minutes, seconds };

      for (const [key, value] of Object.entries(values)) {
        const node = root.querySelector(`[data-countdown-unit="${key}"]`);
        if (node) node.textContent = pad(value);
      }
      const label = root.dataset.label || "Geri sayım";
      root.setAttribute(
        "aria-label",
        diff <= 0
          ? `${label}: geri sayım tamamlandı.`
          : `${label}: ${days} gün ${hours} saat ${minutes} dakika ${seconds} saniye kaldı.`,
      );
    };

    const tick = () => {
      document.querySelectorAll("[data-countdown]").forEach(update);
    };
    tick();
    window.setInterval(tick, 1000);
  })();
</script>
